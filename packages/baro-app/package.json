{
  "name": "baro-ai",
  "version": "0.61.0",
  "description": "Autonomous parallel coding - plan and execute with AI",
  "type": "module",
  "bin": {
    "baro": "./bin/baro"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/postinstall.js"
  ],
  "scripts": {
    "prebuild": "npm --prefix ../baro-memory run build",
    "build": "tsup",
    "postinstall": "node scripts/postinstall.js",
    "spike": "tsx scripts/spike-claude-participant.ts",
    "spike:two": "tsx scripts/spike-claude-participant.ts --two-stories",
    "spike:midflight": "tsx scripts/spike-claude-participant.ts --midflight"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "vectra": "^0.9.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@mozaik-ai/core": "3.12.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jigjoy-ai/baro"
  },
  "keywords": [
    "ai",
    "coding",
    "cli",
    "parallel",
    "autonomous",
    "claude"
  ],
  "license": "MIT"
}
